# =============================================================
# Environment variables — copy this file to .env and fill in
# your actual values. Never commit .env to version control.
# =============================================================

# Weights & Biases API key
# Get yours at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Weights & Biases entity (your username or team name)
WANDB_ENTITY=your_wandb_entity_here

# Weights & Biases project name
WANDB_PROJECT=telco-churn-logit
